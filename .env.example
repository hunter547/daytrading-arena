# Kafka broker address (required by all components)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# LLM provider API key (required by deploy_chat_node.py)
OPENAI_API_KEY=your-api-key-here

# ============================================================================
# TopstepX Authentication (for CME futures trading)
# ============================================================================
# Choose ONE of the following methods:

# Method 1: API Key Authentication (Recommended - Auto-generates JWT token)
# Get these from your TopstepX dashboard
TOPSTEPX_USERNAME=your-username-or-email
TOPSTEPX_API_KEY=your-api-key-here
TOPSTEPX_ENVIRONMENT=demo  # Options: demo, topstepx, alpha-ticks, etc.

# Method 2: Direct JWT Token (if you already have one)
# Tokens expire after 24 hours, so Method 1 is usually better
# TOPSTEPX_JWT_TOKEN=your-jwt-token-here

# Notes:
# - For demo/paper trading, use: TOPSTEPX_ENVIRONMENT=demo
# - For live TopstepX, use: TOPSTEPX_ENVIRONMENT=topstepx
# - Tokens auto-refresh when using Method 1 (username + API key)
# - To manually get a JWT token, run: python topstepx_auth.py --help

# ============================================================================
# Promoted / copy-traded agent
# ============================================================================
# The "promoted" agent whose simulated trades are mirrored to real accounts.
# PROMOTED_AGENT mirrors to the TopstepX account in TOPSTEPX_ACCOUNT_ID, and is
# also the default agent that gets copy-traded to NinjaTrader (below).
PROMOTED_AGENT=
TOPSTEPX_ACCOUNT_ID=

# ============================================================================
# NinjaTrader Bridge copy trading
# ============================================================================
# Copy the copy-agent's buy/sell/close tool calls onto a real NinjaTrader 8
# account via the NinjaTrader Bridge REST API (docs at <url>/docs/v1).
# Requires the bridge add-on running (default http://localhost:5000).
NINJATRADER_ENABLED=true
NINJATRADER_BRIDGE_URL=http://localhost:5000
# Target NinjaTrader account name that mirrors the agent's trades.
NINJATRADER_ACCOUNT=TOF130830
# Agent whose trades are copy-traded. Defaults to PROMOTED_AGENT if unset.
# NINJATRADER_COPY_AGENT=gpt-trader
