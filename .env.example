# Kafka broker address (required by all components)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# LLM provider API key (required by deploy_chat_node.py)
OPENAI_API_KEY=your-api-key-here

# ============================================================================
# TopstepX Authentication (for CME futures trading)
# ============================================================================
# Choose ONE of the following methods:

# Method 1: API Key Authentication (Recommended - Auto-generates JWT token)
# Get these from your TopstepX dashboard
TOPSTEPX_USERNAME=your-username-or-email
TOPSTEPX_API_KEY=your-api-key-here
TOPSTEPX_ENVIRONMENT=demo  # Options: demo, topstepx, alpha-ticks, etc.

# Method 2: Direct JWT Token (if you already have one)
# Tokens expire after 24 hours, so Method 1 is usually better
# TOPSTEPX_JWT_TOKEN=your-jwt-token-here

# Notes:
# - For demo/paper trading, use: TOPSTEPX_ENVIRONMENT=demo
# - For live TopstepX, use: TOPSTEPX_ENVIRONMENT=topstepx
# - Tokens auto-refresh when using Method 1 (username + API key)
# - To manually get a JWT token, run: python topstepx_auth.py --help
