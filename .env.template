# ============================================================================
# Crypto Day Trading Arena - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your credentials
# Command: cp .env.template .env

# ============================================================================
# Kafka Configuration (Required for full trading system)
# ============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ============================================================================
# LLM Configuration (Required for AI agents)
# ============================================================================
OPENAI_API_KEY=your-openai-api-key-here

# ============================================================================
# TopstepX Authentication (For CME Futures Trading)
# ============================================================================
# Get these credentials from your TopstepX dashboard

# Your TopstepX username/email
TOPSTEPX_USERNAME=your-username-or-email@example.com

# Your API key from TopstepX
TOPSTEPX_API_KEY=your-api-key-here

# Environment (demo for paper trading, topstepx for live)
TOPSTEPX_ENVIRONMENT=demo

# JWT token is auto-generated on service startup from username + API key.
# No need to set TOPSTEPX_JWT_TOKEN manually.

# ============================================================================
# MySQL Configuration (Simulated Trading Accounts)
# ============================================================================
MYSQL_ROOT_PASSWORD=root_pass
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=trading
MYSQL_PASSWORD=trading_pass
MYSQL_DATABASE=trading_arena

# ============================================================================
# Live Trading — Promoted Agent (Optional)
# ============================================================================
# Set PROMOTED_AGENT to the agent_name whose sim trades should be mirrored
# to a real TopstepX account (practice, combine, or funded).
# Only ONE agent can be promoted at a time.
PROMOTED_AGENT=

# Specify a TopstepX account ID to trade on (combine or funded account).
# If not set, auto-detects the practice account (PRAC-*).
TOPSTEPX_ACCOUNT_ID=

# Legacy alias — MIRROR_AGENT still works if PROMOTED_AGENT is not set.
# MIRROR_AGENT=

# ============================================================================
# Available TopstepX Environments
# ============================================================================
# - demo              (Demo/Paper Trading)
# - topstepx          (TopstepX Live)
# - alpha-ticks       (Alpha Ticks)
# - aqua-futures      (Aqua Futures)
# - blue-guardian     (Blue Guardian)
# - blusky            (Blusky)
# - day-traders       (Day Traders)
# - e8x               (E8X)
# - funding-futures   (Funding Futures)
# - holaprime         (Holaprime)
# - lucid-trading     (Lucid Trading)
# - phidias           (Phidias)
# - ticktick-trader   (TickTick Trader)
# - topone-futures    (TopOne Futures)
# - tradeify          (Tradeify)
# - tx3-funding       (TX3 Funding)

